# -*- mode: sh -*-
# zsh environment config for macos

# ZSH dotfile locations
export DOTDIR="${DOTDIR:-${HOME}/.config/dotfiles}"
export MYCONF="${MYCONF:-${HOME}/.config/myconf}"
export ZDOTDIR="${ZDOTDIR:-${HOME}/.config/zsh}"

# Homebrew
export HOMEBREW_PREFIX="${HOMEBREW_PREFIX:-/opt/homebrew}"
export HOMEBREW_CASK_OPTS="--appdir=/Applications --no-quarantine"
export HOMEBREW_NO_ANALYTICS=1

# Default ls arguments (GNU-compatible; GNU coreutils added to PATH by bootstrap)
export LS_ARGS="--color=auto --group-directories-first --time-style=long-iso -h"
